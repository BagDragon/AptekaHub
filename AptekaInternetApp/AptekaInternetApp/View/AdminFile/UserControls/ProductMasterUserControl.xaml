<UserControl x:Class="AptekaInternetApp.View.MainWindowFile.UsersControls.ProductMasterUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AptekaInternetApp.View.MainWindowFile.UsersControls"
             mc:Ignorable="d" 
             d:DesignHeight="1000" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Градиент для карточки запасов -->
        <LinearGradientBrush x:Key="StockCardGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#667eea" Offset="0"/>
            <GradientStop Color="#764ba2" Offset="1"/>
        </LinearGradientBrush>

        <!-- Современные стили -->
        <Style x:Key="ModernHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#34495E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#5D6D7E"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="ModernTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#3498DB"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CompactComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#D5DBDB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Height" Value="36"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2980B9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#21618C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#27AE60"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#229954"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1E8449"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#95A5A6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7F8C8D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ImageButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="InfoCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#EAECEE"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#3498DB" Padding="25" BorderBrush="#2980B9" BorderThickness="0,0,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🎯 Управление продуктами" 
                          Style="{StaticResource ModernHeaderStyle}" 
                          Foreground="White"/>
                <TextBlock x:Name="StatusText" Text=" - Добавление нового продукта" 
                          FontSize="16" Foreground="#EBF5FB" 
                          VerticalAlignment="Center" Margin="15,0,0,0"
                          FontFamily="Segoe UI"/>
            </StackPanel>
        </Border>

        <!-- Основной контент -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="350"/>
                </Grid.ColumnDefinitions>

                <!-- Левая панель - Форма продукта -->
                <Border Grid.Column="0" Style="{StaticResource InfoCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Заголовок формы -->
                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Text="📦 Информация о продукте" 
                                   Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Левая колонка -->
                        <!-- Изображение продукта -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="🖼️ Изображение:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <Border Grid.Row="2" Grid.Column="0" Grid.RowSpan="3"
                                Background="#F8F9FA" 
                                BorderBrush="#E0E0E0" 
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="15"
                                Margin="0,0,0,15">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                                <Border Width="120" Height="120" 
                                        Background="White"
                                        BorderBrush="#D5DBDB" 
                                        BorderThickness="2"
                                        CornerRadius="6"
                                        Margin="0,0,0,10">
                                    <Image x:Name="ProductImage" 
                                           Stretch="Uniform"/>
                                </Border>

                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="AddImageButton" 
                                            Content="📁 Добавить" 
                                            Style="{StaticResource ImageButtonStyle}"
                                            Click="AddImageButton_Click"
                                            Margin="0,0,6,0"/>
                                    <Button x:Name="RemoveImageButton" 
                                            Content="🗑️ Удалить" 
                                            Style="{StaticResource ImageButtonStyle}"
                                            Background="#E74C3C"
                                            Click="RemoveImageButton_Click"/>
                                </StackPanel>

                                <TextBlock x:Name="ImageInfoText" 
                                           Text="Изображение не выбрано" 
                                           FontSize="11" 
                                           Foreground="#7F8C8D"
                                           HorizontalAlignment="Center"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Название -->
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="📝 Название:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="2" x:Name="NameTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Категория -->
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="📂 Категория:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Row="4" Grid.Column="2" x:Name="CategoryComboBox" 
                                 Style="{StaticResource CompactComboBoxStyle}" Margin="0,0,0,15"
                                 SelectionChanged="CategoryComboBox_SelectionChanged"
                                 DisplayMemberPath="Name"/>

                        <!-- Подкатегория -->
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="📁 Подкатегория:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Row="6" Grid.Column="2" x:Name="SubcategoryComboBox" 
                                 Style="{StaticResource CompactComboBoxStyle}" Margin="0,0,0,15"
                                 DisplayMemberPath="Name"/>

                        <!-- Производитель -->
                        <TextBlock Grid.Row="7" Grid.Column="2" Text="🏭 Производитель:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <ComboBox Grid.Row="8" Grid.Column="2" x:Name="ManufacturerComboBox" 
                                 Style="{StaticResource CompactComboBoxStyle}" Margin="0,0,0,15"
                                 DisplayMemberPath="NameManufacture"/>

                        <!-- Цена -->
                        <TextBlock Grid.Row="9" Grid.Column="2" Text="💰 Цена (₽):" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="10" Grid.Column="2" x:Name="PriceTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Левая колонка продолжение -->
                        <!-- Форма выпуска -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="💊 Форма выпуска:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="6" Grid.Column="0" x:Name="ReleaseFormTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Дозировка -->
                        <TextBlock Grid.Row="7" Grid.Column="0" Text="⚖️ Дозировка:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="8" Grid.Column="0" x:Name="DosageTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Упаковка -->
                        <TextBlock Grid.Row="9" Grid.Column="0" Text="📦 Упаковка:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="10" Grid.Column="0" x:Name="PackagingTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Количество в упаковке -->
                        <TextBlock Grid.Row="11" Grid.Column="0" Text="🔢 Количество в упаковке:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="12" Grid.Column="0" x:Name="PackageContentsTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Активное вещество -->
                        <TextBlock Grid.Row="13" Grid.Column="0" Text="🧪 Активное вещество:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="14" Grid.Column="0" x:Name="ActiveIngredientTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Правая колонка продолжение -->
                        <!-- Условия хранения -->
                        <TextBlock Grid.Row="11" Grid.Column="2" Text="🌡️ Условия хранения:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox Grid.Row="12" Grid.Column="2" x:Name="StorageConditionsTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,0,15"/>

                        <!-- Срок годности и чекбоксы -->
                        <Grid Grid.Row="15" Grid.ColumnSpan="3" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📅 Срок годности (мес.):" 
                                           Style="{StaticResource LabelStyle}"/>
                                <TextBox x:Name="ShelfLifeTextBox" 
                                        Style="{StaticResource ModernTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <CheckBox x:Name="RequiresPrescriptionCheckBox" 
                                         Content="📋 Рецептурный препарат" 
                                         FontSize="14" FontWeight="Medium" 
                                         Foreground="#5D6D7E"
                                         VerticalAlignment="Center"
                                         Margin="0,0,15,0"/>
                                <CheckBox x:Name="IsActiveCheckBox" 
                                         Content="✅ Активный" 
                                         FontSize="14" FontWeight="Medium" 
                                         Foreground="#5D6D7E"
                                         VerticalAlignment="Center"
                                         IsChecked="True"/>
                            </StackPanel>
                        </Grid>

                        <!-- Кнопки управления -->
                        <StackPanel Grid.Row="16" Grid.ColumnSpan="3" 
                                   Orientation="Horizontal" 
                                   HorizontalAlignment="Right" 
                                   Margin="0,20,0,0">
                            <Button x:Name="ClearButton" Content="🗑️ Очистить" 
                                   Style="{StaticResource SecondaryButtonStyle}" 
                                   Click="ClearButton_Click" Margin="0,0,12,0"/>
                            <Button x:Name="SaveProductButton" Content="💾 Сохранить" 
                                   Style="{StaticResource SuccessButtonStyle}" 
                                   Click="SaveProductButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Правая панель - Управление запасами -->
                <Border Grid.Column="2" Style="{StaticResource InfoCardStyle}">
                    <StackPanel>
                        <TextBlock Text="📊 Управление запасами" 
                                   Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Карточка текущих запасов -->
                        <Border Background="{StaticResource StockCardGradient}" 
                                CornerRadius="8" Padding="20" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Текущие запасы" 
                                           FontWeight="SemiBold" 
                                           Foreground="White" 
                                           FontSize="14"
                                           Margin="0,0,0,8"/>
                                <TextBlock x:Name="CurrentStockText" Text="Не выбрано" 
                                           FontSize="24" FontWeight="Bold" 
                                           Foreground="White"/>
                                <TextBlock x:Name="StockStatusText" Text="Статус: Неизвестно" 
                                           FontSize="12" Foreground="#EBF5FB"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Форма управления запасами -->
                        <TextBlock Text="Текущее количество:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="StockQuantityTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" 
                                Text="0" Margin="0,0,0,15"/>

                        <TextBlock Text="Минимальный запас:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="MinStockTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" 
                                Text="5" Margin="0,0,0,15"/>

                        <TextBlock Text="Максимальный запас:" 
                                   Style="{StaticResource LabelStyle}"/>
                        <TextBox x:Name="MaxStockTextBox" 
                                Style="{StaticResource ModernTextBoxStyle}" 
                                Text="500" Margin="0,0,0,20"/>

                        <Button x:Name="UpdateStockButton" Content="💾 Обновить запасы" 
                               Style="{StaticResource SuccessButtonStyle}" 
                               Click="UpdateStockButton_Click"
                               Margin="0,0,0,25"/>

                        <!-- Быстрый выбор продукта -->
                        <TextBlock Text="🔍 Быстрый выбор продукта:" 
                                   Style="{StaticResource LabelStyle}" 
                                   Margin="0,10,0,8"/>
                        <ComboBox x:Name="QuickProductComboBox" 
                                 Style="{StaticResource CompactComboBoxStyle}"
                                 SelectionChanged="QuickProductComboBox_SelectionChanged"
                                 DisplayMemberPath="Name"/>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>