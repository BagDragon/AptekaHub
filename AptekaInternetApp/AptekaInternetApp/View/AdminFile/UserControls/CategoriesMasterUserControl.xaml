<UserControl x:Class="AptekaInternetApp.View.MainWindowFile.UsersControls.CategoriesMasterUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AptekaInternetApp.View.MainWindowFile.UsersControls"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1000">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Управление категориями" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0 10 0 20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Добавление/Редактирование -->
            <StackPanel Grid.Column="0" Margin="20">
                <Border Padding="15" BorderBrush="#E0E0E0" BorderThickness="2" CornerRadius="10" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="Данные категории" FontSize="16" FontWeight="SemiBold" Margin="0 0 0 15"/>

                        <!-- Поле для ввода SVG Path -->
                        <TextBlock Text="SVG Path код:" FontSize="14" Margin="0 0 0 5"/>
                        <TextBox Name="PathTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True"
                                FontFamily="Consolas" FontSize="11" VerticalScrollBarVisibility="Auto"
                                TextChanged="PathTextBox_TextChanged"
                                ToolTip="Введите SVG Path код. Пример: M12 2C6.48 2 2 6.48 2 12S6.48 22 12 22 22 17.52 22 12 17.52 2 12 2ZM12 20C7.58 20 4 16.42 4 12S7.58 4 12 4 20 7.58 20 12 16.42 20 12 20Z M12 8L8 12 12 16 16 12Z"/>

                        <!-- Preview изображения -->
                        <TextBlock Text="Предпросмотр:" FontSize="14" Margin="0 15 0 5"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" Background="White" 
                                HorizontalAlignment="Center" Padding="10">
                            <Viewbox Width="150" Height="150">
                                <Path Name="PathPreview" Stretch="Uniform" Fill="Black"/>
                            </Viewbox>
                        </Border>

                        <!-- Название категории -->
                        <TextBlock Text="Название категории:" FontSize="14" Margin="0 15 0 5"/>
                        <TextBox Name="NameTextBox" FontSize="16" Height="35" Padding="5"
                                TextChanged="NameTextBox_TextChanged"/>
                        <TextBlock Name="NameValidationText" Foreground="Red" FontSize="12" 
                                  Visibility="Collapsed" Margin="0 2 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки действий -->
                <StackPanel Margin="0 20 0 0">
                    <Button Name="AddButton" Content="Добавить категорию" Click="AddButton_Click"
                            Style="{StaticResource MainsButtons}" Height="45" FontSize="16" FontWeight="SemiBold"/>
                    <Button Name="UpdateButton" Content="Сохранить изменения" Click="UpdateButton_Click"
                            Style="{StaticResource MainsButtons}" Height="45" FontSize="16" FontWeight="SemiBold"
                            Background="#28a745" Margin="0 10 0 0" Visibility="Collapsed"/>
                    <Button Name="CancelButton" Content="Отмена" Click="CancelButton_Click"
                            Style="{StaticResource MainsButtons}" Height="35" FontSize="14" 
                            Background="#6c757d" Margin="0 10 0 0" Visibility="Collapsed"/>
                </StackPanel>
            </StackPanel>

            <!-- Правая панель - Список категорий -->
            <StackPanel Grid.Column="1" Margin="20">
                <TextBlock Text="Список категорий" FontSize="18" FontWeight="SemiBold" Margin="0 0 0 10"/>

                <DataGrid Name="CategoriesDataGrid" AutoGenerateColumns="False" 
                         SelectionChanged="CategoriesDataGrid_SelectionChanged"
                         IsReadOnly="True" Height="600">
                    <DataGrid.Columns>
                        <DataGridTextColumn Width="60" Binding="{Binding ID_Category}" Header="ID"/>
                        <DataGridTextColumn Width="*" Binding="{Binding Name}" Header="Название"/>
                        <DataGridTemplateColumn Width="80" Header="Действия">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="✏️" Tag="{Binding ID_Category}" Click="EditButton_Click"
                                                ToolTip="Редактировать" Background="Transparent" BorderThickness="0"
                                                FontSize="12" Padding="5 2"/>
                                        <Button Content="🗑️" Tag="{Binding ID_Category}" Click="DeleteButton_Click"
                                                ToolTip="Удалить" Background="Transparent" BorderThickness="0"
                                                FontSize="12" Padding="5 2" Margin="5 0 0 0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>