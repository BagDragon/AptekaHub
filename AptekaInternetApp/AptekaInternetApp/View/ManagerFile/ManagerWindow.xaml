<Window x:Class="AptekaInternetApp.View.MainWindowFile.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AptekaInternetApp.View.MainWindowFile"
        mc:Ignorable="d"
        Title="AptekaHub - Панель управления отчётами" Height="900" Width="1600" 
        WindowStartupLocation="CenterScreen"
        Background="#F8FAFC"
        Icon="/Resources/Images/Icons/iconProgram.ico">

    <Window.Resources>
        <LinearGradientBrush x:Key="LogoGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#30a8ff" Offset="0"/>
            <GradientStop Color="#1E88E5" Offset="0.7"/>
            <GradientStop Color="#1565C0" Offset="1"/>
        </LinearGradientBrush>

     

        <!-- Современный стиль для кнопок бокового меню -->
        <Style x:Key="ModernMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="12" 
                                BorderThickness="0"
                                Margin="8,4">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EFF6FF"/>
                                <Setter Property="Foreground" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DBEAFE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопок меню пользователя -->
        <Style x:Key="UserMenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Left" 
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F3F4F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для иконок в меню -->
        <Style x:Key="MenuIconStyle" TargetType="Path">
            <Setter Property="Fill" Value="#6B7280"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Стиль для заголовков разделов меню -->
        <Style x:Key="MenuSectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="Margin" Value="20,0,0,8"/>
            <Setter Property="Text" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковая панель -->
        <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- Заголовок с логотипом -->
                <Border DockPanel.Dock="Top" Background="White" Padding="20,20,20,10" 
                        BorderBrush="#F3F4F6" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Cursor="Hand">
                        <!-- Векторный логотип аптеки -->
                        <Border Width="44" 
                                Height="44" 
                                Background="{StaticResource LogoGradient}"
                                CornerRadius="10"
                                Margin="0,0,12,0">
                            <Viewbox Stretch="Uniform" Margin="8">
                                <Grid>
                                    <!-- Крест медицины -->
                                    <Path Data="M12 2L9 5 12 8 15 5z M8 7L5 10 8 13 11 10z M16 7L13 10 16 13 19 10z M12 14L9 17 12 20 15 17z" 
                                          Fill="White" 
                                          Stretch="Uniform"/>
                                    <!-- Капля -->
                                    <Path Data="M12 2C12 2 16 6 16 10C16 13.31 13.31 16 10 16C6.69 16 4 13.31 4 10C4 6 8 2 12 2Z" 
                                          Fill="White" 
                                          Stretch="Uniform"
                                          Opacity="0.8"/>
                                </Grid>
                            </Viewbox>
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock FontSize="20" FontWeight="Bold">
                                <Run Foreground="#30a8ff">Apteka</Run>
                                <Run Foreground="#111827">Hub</Run>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#6B7280" Margin="0,2,0,0">
                                Панель управления
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Меню навигации -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto" Padding="8,16">
                    <StackPanel>
                        <TextBlock Text="Отчёты" Style="{StaticResource MenuSectionHeaderStyle}"/>

                        <!-- Кнопка отчётов по продажам -->
                        <Button Style="{StaticResource ModernMenuButtonStyle}" 
                                Name="ReportSalesButton" 
                                Click="ReportSalesButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource MenuIconStyle}"
                                      Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"/>
                                <TextBlock Text="Отчёты по продажам" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Кнопка отчётов по складу -->
                        <Button Style="{StaticResource ModernMenuButtonStyle}" 
                                Name="ReportWarehouse" 
                                Click="ReportWarehouse_Click">
                            <StackPanel Orientation="Horizontal">
                                <Path Style="{StaticResource MenuIconStyle}"
                                      Data="M20 6h-4V4c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zM10 4h4v2h-4V4zm10 16H4V8h16v12z"/>
                                <TextBlock Text="Отчёты по складу" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Разделитель -->
                        <Border Height="1" Background="#F3F4F6" Margin="16,20"/>
                                            
                    </StackPanel>
                </ScrollViewer>

                <!-- Нижняя часть с информацией о пользователе -->
                <Border DockPanel.Dock="Bottom" Background="#F8FAFC" Padding="16" 
                        BorderBrush="#E5E7EB" BorderThickness="0,1,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" 
                                    MouseDown="UserInfo_MouseDown"
                                    Cursor="Hand"
                                    Background="Transparent">
                            <Border Width="40" Height="40" Background="#EFF6FF" 
                                    CornerRadius="20" Margin="0,0,12,0">
                                <Image Source="/Resources/Images/Main/avatar.png" 
                                       Stretch="Uniform"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="NameUser" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="#111827" Text="Иван Иванов"/>
                                <TextBlock x:Name="RoleUser" FontSize="12" 
                                           Foreground="#6B7280" Text="Старший фармацевт"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Основная область контента -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="White" Padding="24,16" 
                    BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Заголовок страницы -->
                    <TextBlock x:Name="PageTitle" Grid.Column="0" 
                               Text="Главная панель"
                               FontSize="24" FontWeight="Bold" 
                               Foreground="#111827" VerticalAlignment="Center"/>

                    <!-- Статус и время -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" 
                                VerticalAlignment="Center">
                        <TextBlock x:Name="CurrentTime" FontSize="14" 
                                   Foreground="#6B7280" VerticalAlignment="Center"
                                   Margin="0,0,16,0"/>
                        <Border Background="#ECFDF5" Padding="8,4" CornerRadius="6">
                            <TextBlock Text="Online" FontSize="12" FontWeight="Medium" 
                                       Foreground="#065F46"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Область контента -->
            <Border Grid.Row="1" Background="#F8FAFC" Padding="24">
                <ContentControl x:Name="ViewUserControls">
                    <!-- Контент по умолчанию -->
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="80" Height="80" Background="#EFF6FF" 
                                    CornerRadius="20" Margin="0,0,0,16">
                                <Viewbox Stretch="Uniform" Margin="16">
                                    <Path Data="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z" 
                                          Fill="#30a8ff"/>
                                </Viewbox>
                            </Border>
                            <TextBlock Text="Добро пожаловать в AptekaHub" 
                                       FontSize="20" FontWeight="SemiBold" 
                                       Foreground="#111827" TextAlignment="Center"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="Выберите раздел в меню слева для начала работы" 
                                       FontSize="14" Foreground="#6B7280" 
                                       TextAlignment="Center" MaxWidth="300"/>
                        </StackPanel>
                    </Grid>
                </ContentControl>
            </Border>
        </Grid>

        <!-- Всплывающее меню пользователя -->
        <Border Panel.ZIndex="100" 
                x:Name="ActionUserPanel" 
                Visibility="Collapsed" 
                Background="White" 
                CornerRadius="12" 
                BorderThickness="1"
                Width="240" 
                Padding="8"  
                HorizontalAlignment="Right" 
                VerticalAlignment="Top" 
                Margin="24,80,24,0">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.15" Color="Black"/>
            </Border.Effect>
            <Border.BorderBrush>
                <SolidColorBrush Color="#E5E5E5"/>
            </Border.BorderBrush>

            <StackPanel>
                <!-- Информация о пользователе -->
                <Border Background="#F8FAFC" Padding="12" CornerRadius="8" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock x:Name="PopupUserName" FontWeight="SemiBold" 
                                   Foreground="#111827" Text="Иван Иванов"/>
                        <TextBlock x:Name="PopupUserRole" FontSize="12" 
                                   Foreground="#6B7280" Text="Менеджер"/>
                    </StackPanel>
                </Border>

                <!-- Разделитель -->
                <Border Height="1" Background="#F3F4F6" Margin="0,4"/>

                <!-- Кнопка выхода -->
                <Button Style="{StaticResource UserMenuButtonStyle}" 
                        Name="ExitButton" 
                        Click="ExitButton_Click">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" 
                              Fill="#DC3545" 
                              Stretch="Uniform" 
                              Width="16" 
                              Height="16" 
                              Margin="0,0,12,0"/>
                        <TextBlock Foreground="#DC3545" Text="Выйти" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>