<UserControl x:Class="AptekaInternetApp.View.LoginAndRegWindows.UserControls.ChangePasswordUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="InputField" TargetType="Control">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#30a8ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="🔑" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock Text="Новый пароль" Foreground="#333333" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Придумайте надежный пароль" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <TextBox Name="NewPassword" 
                     Background="#FFFFFF"
                     Foreground="#333333"
                     BorderBrush="#E5E5E5"
                     BorderThickness="1"
                     
                     Padding="15"
                     FontSize="14"
                     Margin="0,0,0,15"/>

        <TextBox Name="ConfirmedNewPassword" 
                     Background="#FFFFFF"
                     Foreground="#333333"
                      BorderBrush="#E5E5E5"
                     BorderThickness="1"
                     
                     Padding="15"
                     FontSize="14"
                     Margin="0,0,0,30"/>

        <Button Name="ChangePasswordButton" Style="{StaticResource PrimaryButton}" 
                Content="Сохранить" Click="ChangePasswordButton_Click"/>
    </StackPanel>
</UserControl>
