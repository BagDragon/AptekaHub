<UserControl x:Class="AptekaInternetApp.View.LoginAndRegWindows.UserControls.CodeEnterUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#30a8ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Center">
        <TextBlock Text="📧" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        <TextBlock Text="Код подтверждения" Foreground="#333333" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        <TextBlock Text="Отправлен на ****@mail.com" Foreground="#666666" HorizontalAlignment="Center" Margin="0,0,0,30"/>

        <TextBox Name="InputCodeTextBox" Style="{StaticResource InputField}" 
                 FontSize="18" TextAlignment="Center" MaxLength="4"
                 Margin="0,0,0,20" Width="120"/>

        <TextBlock Name="TimerTextBlock" Foreground="#30a8ff" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Button Name="ConfirmEmailButton" Style="{StaticResource PrimaryButton}" 
                Content="Подтвердить" Click="ConfirmEmailButton_Click" Margin="0,0,0,10"/>

        <TextBlock Foreground="#30a8ff" HorizontalAlignment="Center" Cursor="Hand" >
            <Hyperlink Name="SendAgainPasswordHyperLink" Click="SendAgainPasswordHyperLink_Click">Отправить код снова</Hyperlink>
        </TextBlock>
    </StackPanel>
</UserControl>
