<Window x:Class="AptekaInternetApp.View.LoginAndRegWindows.AuthorizationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AptekaInternetApp.View.LoginAndRegWindows"
        mc:Ignorable="d"
        Title="AptekaApp. Авторизация" 
        Height="420" Width="600" WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown"
        Icon="/Resources/Images/Icons/iconProgram.ico">
    
        <StackPanel HorizontalAlignment="Center" 
                VerticalAlignment="Center">
        <TextBlock Margin="0 0 0 0" FontSize="35" HorizontalAlignment="Center" TextWrapping="Wrap" Width="410" TextAlignment="Center" Foreground="#30a8ff" FontWeight="Medium"> <Run Foreground="#30a8ff" FontWeight="Bold">Apteka</Run><Run FontWeight="Bold" Foreground="#333">Hub</Run></TextBlock>
        <TextBlock Margin="0 10 0 0" FontSize="35" HorizontalAlignment="Center" Foreground="#30a8ff" FontWeight="Bold">Вход в систему</TextBlock>
        <Border Margin="0 20 0 0" Width="385" Padding="3" BorderBrush="#30a8ff" BorderThickness="3" CornerRadius="10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox Width="320" Name="UserLogin" Style="{StaticResource NoBlueBorderTextBox}" Height="50" FontSize="30"  BorderBrush="Transparent" HorizontalAlignment="Left"></TextBox>
            </StackPanel>
            </Border>
        <Border Margin="0 20 0 0" Padding="3" Width="385" BorderBrush="#30a8ff" BorderThickness="3" CornerRadius="10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <PasswordBox x:Name="User_password" Width="320" Height="50" Style="{StaticResource NoBlueBorderPasswordBox}" BorderBrush="Transparent"  FontSize="30"  HorizontalAlignment="Left" PasswordChanged="User_password_PasswordChanged" ></PasswordBox>
                <TextBox  x:Name="User_passwordTextBox" TextChanged="User_passwordTextBox_TextChanged" Width="320" Visibility="Collapsed" Height="50" Style="{StaticResource NoBlueBorderTextBox}" BorderBrush="Transparent"  FontSize="30"  HorizontalAlignment="Left"></TextBox>
                <Button Height="50" Width="50" Background="Transparent" BorderBrush="Transparent" Name="VisiblePasswordButton" Click="VisiblePasswordButton_Click">
                    <Image Height="45" Width="45" Source="\Resources\Images\Main\eye.jpg"></Image>
                    
                </Button>
                </StackPanel>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
                
            <Button Style="{StaticResource TextButtonStyle}" Name="InRegistrationWindowButton" Click="InRegistrationWindowButton_Click">
                <TextBlock FontSize="16" Margin="0 0 50 0"  Foreground="#30a8ff" FontWeight="Bold">Регистрация</TextBlock>
            </Button>
            <Button Style="{StaticResource TextButtonStyle}" Name="HelpPasswordButton" Click="HelpPasswordButton_Click">
                <TextBlock FontSize="16" FontWeight="Bold" Foreground="#30a8ff">Забыл пароль</TextBlock>
            </Button>
            </StackPanel>

        <Button Margin="0 20 0 0" Width="300" Template="{StaticResource MainButtons}" Background="#30a8ff" Style="{StaticResource ButtonStyle}" Click="AutorizationButton_Click">Авторизация</Button>

        </StackPanel>
    
</Window>
