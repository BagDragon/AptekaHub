<Window x:Class="AptekaInternetApp.View.PharmacistFile.PrescriptionInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AptekaInternetApp.View.PharmacistFile"
        mc:Ignorable="d"
        Title="Ввод рецепта" Height="600" Width="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="/Resources/Images/Icons/iconProgram.ico">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="Ввод данных рецепта" 
                   FontSize="20" FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <!-- Форма ввода -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Информация о товаре -->
                <Border Background="#F8F9FA" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Информация о товаре:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding ProductName}" FontSize="14"/>
                    </StackPanel>
                </Border>

                <!-- Данные рецепта -->
                <GroupBox Header="Данные рецепта" Padding="10">
                    <StackPanel>
                        <!-- ФИО пациента -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="ФИО пациента*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PatientNameTextBox" Height="30" FontSize="14"
                                   Text="{Binding PatientName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Номер рецепта -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Номер рецепта*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PrescriptionNumberTextBox" Height="30" FontSize="14"
                                   Text="{Binding PrescriptionNumber, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Врач -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="ФИО врача*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="DoctorNameTextBox" Height="30" FontSize="14"
                                   Text="{Binding DoctorName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <!-- Даты -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Дата выдачи*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="IssueDatePicker" Height="30"
                                          SelectedDate="{Binding IssueDate}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Срок действия*" FontWeight="SemiBold" Margin="0,0,0,5"/>
                                <DatePicker x:Name="ExpiryDatePicker" Height="30"
                                          SelectedDate="{Binding ExpiryDate}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Валидация -->
                <Border x:Name="ValidationBorder" Background="#FFF5F5F5" BorderBrush="#FFE0A8A8" 
                        BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,10,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ValidationTextBlock" TextWrapping="Wrap" 
                             Foreground="#D32F2F" FontSize="12"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="CancelButton_Click" 
                    Style="{StaticResource SecondaryButtonStyle}"/>
            <Button Content="Сохранить" Width="100" Height="35" 
                    Click="SaveButton_Click" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    Margin="10,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
