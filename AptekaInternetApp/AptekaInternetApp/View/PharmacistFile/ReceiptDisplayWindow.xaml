<Window x:Class="AptekaInternetApp.View.PharmacistFile.ReceiptDisplayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AptekaInternetApp.View.PharmacistFile"
        mc:Ignorable="d"
        Title="Чек покупки" 
        Width="450" 
        Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White"
        Icon="/Resources/Images/Icons/iconProgram.ico">
    
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#30a8ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,0"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanPrescriptionConverter"/>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6c757d"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#30a8ff" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="АПТЕКА" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           HorizontalAlignment="Center"/>
                <TextBlock Text="КАССОВЫЙ ЧЕК" 
                           FontSize="16" 
                           Foreground="White" 
                           HorizontalAlignment="Center"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Содержимое чека -->
        <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <StackPanel>
                    <!-- Информация о чеке -->
                    <StackPanel Margin="0,0,0,10">
                        <TextBlock x:Name="ReceiptNumberText" 
                                   FontSize="16" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock x:Name="SaleDateText"
                                   FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                        <TextBlock x:Name="CashierNameText"
                                   FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                    </StackPanel>

                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,5,0,10"/>

                    <!-- Список товаров -->
                    <ItemsControl x:Name="ItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F0F0F0" BorderThickness="0,0,0,1" Padding="0,8,0,8" Margin="0,0,0,5">
                                    <StackPanel>
                                        <TextBlock Text="{Binding ProductName}" 
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextWrapping="Wrap"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding Quantity, StringFormat='{}{0} x '}" 
                                                       FontSize="11" Foreground="#666"/>
                                            <TextBlock Text="{Binding PriceWithDiscount, StringFormat='{}{0:N2} ₽'}" 
                                                       FontSize="11" Foreground="#666"/>
                                            <TextBlock Text="{Binding Total, StringFormat='{}= {0:N2} ₽'}" 
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Margin="5,0,0,0"/>
                                        </StackPanel>

                                        <!-- Маркер рецептурного товара -->
                                        <Border Background="#FF6B8E23" Width="100" CornerRadius="10" Padding="6,2" Margin="0,10,0,0" Visibility="{Binding RequiresPrescription, Converter={StaticResource BooleanPrescriptionConverter}}">
                                            <TextBlock Text="Рецепт" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" 
Foreground="White" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Rectangle Height="1" Fill="#E0E0E0" Margin="0,10,0,10"/>

                    <!-- Итоги -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="Сумма:" FontSize="13" Foreground="#666" Width="200"/>
                            <TextBlock x:Name="SubtotalText"
                                       FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,3">
                            <TextBlock Text="Скидка:" FontSize="13" Foreground="#666" Width="200"/>
                            <TextBlock x:Name="DiscountText"
                                       FontSize="13" FontWeight="SemiBold" Foreground="#28A745" HorizontalAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="ИТОГО:" FontSize="15" FontWeight="Bold" Width="200"/>
                            <TextBlock x:Name="TotalText"
                                       FontSize="15" FontWeight="Bold" Foreground="#30a8ff" HorizontalAlignment="Right"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Подпись -->
                    <Border Background="#F8F9FA" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                        <TextBlock Text="СПАСИБО ЗА ПОКУПКУ!" 
                                   FontSize="12" FontWeight="Bold" 
                                   Foreground="#666" HorizontalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button Content="Сохранить в PDF" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SavePdfButton_Click"
                    ToolTip="Сохранить чек в PDF файл"/>
            <Button Content="Закрыть" 
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
