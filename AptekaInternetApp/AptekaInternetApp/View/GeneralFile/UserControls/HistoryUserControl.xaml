<UserControl x:Class="AptekaInternetApp.View.MainWindowFile.UsersControls.HistoryUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:AptekaInternetApp.ViewModel"
             xmlns:local="clr-namespace:AptekaInternetApp.View.MainWindowFile.UsersControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000">
    <UserControl.Resources>
        <Style x:Key="SaleCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333333"/>
        </Style>

        <Style x:Key="DetailTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#666666"/>
        </Style>

        <Style x:Key="AmountTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#30a8ff"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#6C757D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="20" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="История продаж" FontSize="28" FontWeight="Medium"/>
                <TextBlock x:Name="SalesCountText" Text=" (загружается...)" FontSize="16" 
                           Foreground="Gray" VerticalAlignment="Center" Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Список продаж -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
            <ItemsControl x:Name="SalesItemsControl" ItemsSource="{Binding Sales}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource SaleCardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Заголовок продажи -->
                                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,15">
                                    <TextBlock Style="{StaticResource HeaderTextStyle}" 
                                               Text="{Binding ReceiptNumber, StringFormat='Чек №: {0}'}"/>
                                    <TextBlock Style="{StaticResource DetailTextStyle}" 
                                               Text="{Binding SaleDate, StringFormat=' от {0:dd.MM.yyyy HH:mm}'}"
                                               Margin="20,0,0,0"/>
                                </StackPanel>

                                <!-- Информация о продаже -->
                                <StackPanel Grid.Row="1" Grid.Column="0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Кассир:"/>
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="{Binding CashierName}" 
                                                   FontWeight="SemiBold" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Клиент:"/>
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="{Binding Customer}" 
                                                   FontWeight="SemiBold" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <!--<StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Тип оплаты:"/>
                                        <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                   Text="{Binding PaymentTypeString}" 
                                                   FontWeight="SemiBold" Margin="5,0,0,0"/>
                                    </StackPanel>-->
                                </StackPanel>

                                <!-- Суммы -->
                                <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Сумма:"/>
                                        <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                   Text="{Binding TotalAmount, StringFormat={}{0:N2} руб.}" 
                                                   FontWeight="SemiBold" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Скидка:"/>
                                        <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                   Text="{Binding DiscountAmount, StringFormat={}{0:N2} руб.}" 
                                                   Foreground="#28A745" FontWeight="SemiBold" Margin="5,0,0,0"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource DetailTextStyle}" Text="Итого:"/>
                                        <TextBlock Style="{StaticResource AmountTextStyle}" 
                                                   Text="{Binding FinalAmount, StringFormat={}{0:N2} руб.}" 
                                                   Margin="5,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Товары -->
                                <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#F8F9FA" 
                                        CornerRadius="4" Padding="10" Margin="0,15,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Товары:" Style="{StaticResource HeaderTextStyle}" 
                                                   Margin="0,0,0,10"/>

                                        <ItemsControl ItemsSource="{Binding Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" 
                                                            Padding="0,8,0,8" Margin="0,0,0,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Column="0" Style="{StaticResource DetailTextStyle}" 
                                                                       Text="{Binding ProductName}" TextWrapping="Wrap"/>

                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0">
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" Text="Кол-во:"/>
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                                           Text="{Binding Quantity}" FontWeight="SemiBold" 
                                                                           Margin="5,0,0,0"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="20,0,0,0">
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" Text="Цена:"/>
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                                           Text="{Binding PriceWithDiscount, StringFormat={}{0:N2} руб.}" 
                                                                           FontWeight="SemiBold" Margin="5,0,0,0"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="20,0,0,0">
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" Text="Сумма:"/>
                                                                <TextBlock Style="{StaticResource DetailTextStyle}" 
                                                                           Text="{Binding Total, StringFormat={}{0:N2} руб.}" 
                                                                           FontWeight="SemiBold" Margin="5,0,0,0"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Кнопка деталей -->
                                <Button Grid.Row="3" Grid.ColumnSpan="2" 
                                        Content="Показать детали" 
                                        Click="ShowDetails_Click"
                                        Tag="{Binding SaleId}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        HorizontalAlignment="Right" 
                                        Margin="0,15,0,0" 
                                        Padding="15,8"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Сообщение при отсутствии продаж -->
        <Border x:Name="NoSalesMessage" Grid.Row="1" Visibility="Collapsed" 
                Background="White" Padding="40" Margin="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Продажи не найдены" 
                           FontSize="20" FontWeight="Medium" 
                           Foreground="#6C757D" TextAlignment="Center"/>
                <TextBlock Text="Здесь будут отображаться все завершенные продажи" 
                           FontSize="14" Foreground="#ADB5BD" 
                           TextAlignment="Center" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
