<UserControl x:Class="AptekaInternetApp.View.GeneralFile.UserControls.CatalogPanelUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AptekaInternetApp.View.GeneralFile.UserControls"
             mc:Ignorable="d" 
              Height="600" Width="600">

    <Border Background="White"
            BorderBrush="#E5E5E5"
            BorderThickness="0 1 1 1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.15" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <!-- Категории -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="CategoriesItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="20,12" 
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseEnter="CategoryItem_MouseEnter"
                                    MouseLeave="CategoryItem_MouseLeave"
                                    MouseDown="CategoryItem_MouseDown">
                                <!-- Добавлен обработчик клика -->
                                <Border.Tag>
                                    <Binding/>
                                </Border.Tag>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Viewbox Width="20" Height="20" Margin="0,0,12,0">
                                        <Path Data="{Binding ImageCategory}" 
                                              Fill="#30a8ff" 
                                              Stretch="Uniform"/>
                                    </Viewbox>
                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="20" 
                                               FontWeight="SemiBold"
                                               Foreground="#333"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Подкатегории -->
            <Border Grid.Column="1"
                    Background="Transparent"
                    BorderBrush="#E5E5E5"                   
                    Padding="2,12"
                    BorderThickness="1 0 0 0"
                    Visibility="Collapsed"
                    x:Name="SubcategoriesBorder">
                <ScrollViewer VerticalScrollBarVisibility="Auto" 
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True">

                    <ItemsControl x:Name="SubcategoriesItemsControl" 
                      Margin="20,0,0,0" 
                      HorizontalAlignment="Left">

                        <!-- Важно: задаем панель для элементов -->
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <!-- Стиль для элементов чтобы они занимали всю ширину -->
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button BorderBrush="Transparent" 
                                        BorderThickness="0"
                                        Tag="{Binding}"
                                        Click="SubcategoryButton_Click"                                       
                                        Background="Transparent"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Left"
                                        Padding="0,8"
                                        Margin="0,2">

                                    <TextBlock Text="{Binding Name}" 
                                               FontSize="16" 
                                               FontWeight="Normal"
                                               Foreground="#333"
                                               VerticalAlignment="Center"
                                               TextAlignment="Left"
                                               TextWrapping="Wrap"/>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</UserControl>
