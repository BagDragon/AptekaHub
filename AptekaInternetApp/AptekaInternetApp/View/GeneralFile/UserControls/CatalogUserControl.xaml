<UserControl x:Class="AptekaInternetApp.View.MainWindowFile.UsersControls.CatalogUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AptekaInternetApp.View.MainWindowFile.UsersControls"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1680">
    <UserControl.Resources>
        <Style x:Key="FilterCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="FilterItemStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#30a8ff"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,0"/>
        </Style>

        <!-- Конвертеры для видимости -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanPrescriptionConverter"/>


        <!-- Инверсный конвертер (показывает когда false) -->
        <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>

        <local:CartVisibilityConverter x:Key="CartVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="#F8F9FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar - Filters -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Hidden" PreviewMouseWheel="LeftScrollViewer_PreviewMouseWheel" Margin="0,0,20,0">
                <StackPanel>
                    <!-- Subcategories Filter -->
                    <Border Style="{StaticResource FilterCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Подкатегории" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="#333" Margin="0,0,0,16"/>
                            <ListView x:Name="subcategoryListView" SelectionChanged="categoryListView_SelectionChanged"
                                      BorderThickness="0" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource FilterItemStyle}">
                                            <TextBlock FontSize="14" Foreground="#495057" Text="{Binding Name}" 
                                                       HorizontalAlignment="Left" FontWeight="Medium"/>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#30a8ff"/>
                                                <Setter Property="BorderBrush" Value="#30a8ff"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E7F3FF"/>
                                                <Setter Property="BorderBrush" Value="#30a8ff"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </StackPanel>
                    </Border>

                    <!-- Brands Filter -->
                    <Border Style="{StaticResource FilterCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Бренды" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="#333" Margin="0,0,0,16"/>
                            <ListView x:Name="brandsListView" SelectionChanged="brandsListView_SelectionChanged"
                                      BorderThickness="0" Background="Transparent">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource FilterItemStyle}">
                                            <TextBlock FontSize="14" Foreground="#495057" Text="{Binding NameManufacture}" 
                                                       HorizontalAlignment="Left" FontWeight="Medium"/>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#30a8ff"/>
                                                <Setter Property="BorderBrush" Value="#30a8ff"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E7F3FF"/>
                                                <Setter Property="BorderBrush" Value="#30a8ff"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right Side - Products -->
            <ScrollViewer Grid.Column="1" PreviewMouseWheel="RightScrollViewer_PreviewMouseWheel" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Products ListView -->
                    <ListView x:Name="ListViewProducts" 
                              Loaded="ListViewProducts_Loaded"
                              SelectionChanged="ListViewProducts_SelectionChanged"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled" 
                              Background="Transparent" 
                              BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="20" Margin="0,0,0,16" 
                                        Background="White" 
                                        BorderBrush="#F0F0F0" 
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Product Image -->
                                        <Border Grid.RowSpan="2" Grid.Column="0" 
                                                Background="#F8F9FA"
                                                Width="140" Height="140" 
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Image Source="{Binding ImageCatalogProduct}" 
                                                   Stretch="Uniform" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Width="130" Height="130"/>
                                        </Border>

                                        <!-- Product Info -->
                                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="16,0,0,0">
                                            <TextBlock FontSize="18" FontWeight="SemiBold" 
                                                       Text="{Binding NameProduct}" TextWrapping="Wrap"
                                                       Foreground="#333" Margin="0,0,0,12"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <TextBlock FontSize="13" Text="Действующее вещество:" 
                                                           Margin="0,0,8,0" Foreground="#6C757D"/>
                                                <TextBlock FontSize="13" Text="{Binding ActiveSubstance}" 
                                                           FontWeight="SemiBold" Foreground="#495057"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock FontSize="13" Text="На складе:" 
                                                           Margin="0,0,8,0" Foreground="#6C757D"/>
                                                <TextBlock FontSize="13" Text="{Binding CountOnWarehouse}" 
                                                           FontWeight="SemiBold" Foreground="#28A745"/>
                                            </StackPanel>

                                            <Border Background="#FF6B8E23" Width="100" HorizontalAlignment="Left" CornerRadius="10" Padding="6,2" 
            Margin="0,10,0,0"
            Visibility="{Binding RequiresPrescription, Converter={StaticResource BooleanPrescriptionConverter}}">
                                                <TextBlock Text="Рецепт" HorizontalAlignment="Center" FontSize="11" FontWeight="Bold" 
                   Foreground="White" VerticalAlignment="Center"/>
                                            </Border>



                                        </StackPanel>

                                        <!-- Price and Cart Controls -->
                                        <StackPanel Grid.Column="2" Grid.RowSpan="2" VerticalAlignment="Center">

                                            <TextBlock FontSize="16" FontWeight="SemiBold" 
               Text="{Binding CatalogPrice, StringFormat=\{0:0\} ₽}"
               Foreground="#6C757D" HorizontalAlignment="Center" 
               Margin="0,0,0,4"
               Visibility="{Binding HasDiscount, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock.TextDecorations>
                                                    <TextDecoration Location="Strikethrough"/>
                                                </TextBlock.TextDecorations>
                                            </TextBlock>

                                            <!-- Цена со скидкой -->
                                            <TextBlock FontSize="24" FontWeight="Bold" 
               Text="{Binding PriceWithDiscount, StringFormat=\{0:0\} ₽}"
               Foreground="#30a8ff" HorizontalAlignment="Center" 
               Margin="0,0,0,4"/>


                                            <!-- StackPanel для кнопок корзины - скрывается для админа -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                Visibility="{Binding Converter={StaticResource CartVisibilityConverter}}">

                                                <!-- Кнопка "В корзину" - показывается когда товара НЕТ в корзине -->
                                                <Button Style="{StaticResource PrimaryButtonStyle}" 
                x:Name="AddToCart" 
                Click="AddToCart_Click"
                Tag="{Binding}"
                Height="48" FontSize="16" FontWeight="SemiBold"
                Padding="24,0" MinWidth="140"
                Visibility="{Binding IsInCart, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                    <TextBlock Text="В корзину" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                                </Button>

                                                <!-- Контрол количества - показывается когда товар в корзине -->
                                                <StackPanel Orientation="Horizontal" 
                    Visibility="{Binding IsInCart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Border Width="35" Height="35" Background="LightGray" BorderBrush="Gray"
         BorderThickness="1" CornerRadius="5">
                                                        
                                                        <Button Content="-" Width="35" Height="35" FontSize="16" FontWeight="Bold"
                     Background="Transparent" BorderBrush="Transparent"
                    Tag="{Binding Id}" Click="QuantityMinus_Click"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding CartQuantity}" 
                       Width="40" Height="35" TextAlignment="Center" VerticalAlignment="Center"
                       FontSize="16" FontWeight="SemiBold" Background="White" Margin="5,0"/>
                                                    <Border Width="35" Height="35" Background="LightGray" BorderBrush="Gray"
                                                            BorderThickness="1" CornerRadius="5">
                                                        <Button Content="+"  FontSize="16" FontWeight="Bold"
                      Background="Transparent" BorderBrush="Transparent"
                    Tag="{Binding Id}" Click="QuantityPlus_Click"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Admin buttons - показываются только для админа -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" 
                Visibility="{Binding Converter={StaticResource CartVisibilityConverter}, ConverterParameter=inverse}">
                                                <Button Width="48" Height="48"
                x:Name="UpdateDateProductButton" 
                Click="UpdateDateProduct_Click" 
                Margin="12,0,0,0"
                BorderBrush="Transparent"
                Tag="{Binding}">
                                                    <Image Source="/Resources/Images/Main/pen.jpg" />
                                                </Button>

                                                <Button Width="48" Height="48"
                x:Name="DeleteProductButton" 
                Click="DeleteProduct_Click" 
                Margin="8,0,0,0"
                 BorderBrush="Transparent"
                Tag="{Binding}">
                                                    <Image Source="/Resources/Images/Main/cross.png" Width="22" Height="22"/>
                                                </Button>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <!-- ИСПРАВЛЕНИЕ: VirtualizingStackPanel должен быть здесь -->
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel VirtualizingStackPanel.IsVirtualizing="True"
                                                        VirtualizingStackPanel.VirtualizationMode="Recycling"/>
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="{x:Type ListViewItem}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- Empty State -->
                    <Border x:Name="EmptyState" Visibility="Collapsed" 
                            Background="White" Padding="40"
                            BorderBrush="#F0F0F0" BorderThickness="1"
                            HorizontalAlignment="Stretch">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Товары не найдены" 
                                       FontSize="18" FontWeight="Medium" 
                                       Foreground="#6C757D" TextAlignment="Center"/>
                            <TextBlock Text="Попробуйте изменить параметры фильтрации" 
                                       FontSize="14" Foreground="#ADB5BD" 
                                       TextAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>